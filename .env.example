# Environment Variables for Spotify Web Clone

# Backend API Configuration
VITE_API_URL=http://localhost:8000/
VITE_API_PORT=8000

# Google OAuth Configuration (optional - for real Google login)
# Get these from Google Cloud Console: https://console.cloud.google.com/
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id_here

# Demo Mode Notes:
# - If VITE_GOOGLE_CLIENT_ID is not set or empty, the app runs in demo mode
# - Google OAuth is replaced with a mock login button
# - All other features work normally with mock data
# - Set VITE_GOOGLE_CLIENT_ID to enable real Google authentication